      "width": 664,
      "height": 19.599999999999998,
      "text": "ASSESSMENT SUBMISSION — END TO END FLOW",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#d9480f",
      "backgroundColor": "transparent",
