      "y": 1091,
      "width": 664,
      "height": 15.399999999999999,
      "text": "      { questionPayload: original Qs, resultPayload: scores + swap + timestamp }",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "opacity": 100,
