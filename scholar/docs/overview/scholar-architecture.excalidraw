      "type": "text",
      "x": 1670,
      "y": 1142,
      "width": 664,
      "height": 15.399999999999999,
      "text": "8.  Trigger /persist-attempt-artifacts:",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
