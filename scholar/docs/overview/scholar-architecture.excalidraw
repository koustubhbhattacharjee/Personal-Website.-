      "y": 1108,
      "width": 664,
      "height": 15.399999999999999,
      "text": "6.  Return {score, total, updatedScores[], swap{}, trends{}}",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
