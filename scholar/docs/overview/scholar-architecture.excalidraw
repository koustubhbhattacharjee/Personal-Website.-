      "x": 1670,
      "y": 1074,
      "width": 664,
      "height": 15.399999999999999,
      "text": "5.  Create ASSESSMENT_ATTEMPTS_DB record:",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "opacity": 100,
