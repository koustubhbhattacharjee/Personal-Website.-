    },
    {
      "id": "el_346",
      "type": "text",
      "x": 1670,
      "y": 938,
      "width": 664,
      "height": 15.399999999999999,
      "text": "1.  Student submits answers at /assessment",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "opacity": 100,
      "angle": 0,
      "roughness": 0,
      "fontWeight": "normal",
      "boundElements": []
    },
    {
      "id": "el_347",
      "type": "text",
      "x": 1670,
      "y": 955,
      "width": 664,
      "height": 15.399999999999999,
      "text": "2.  POST /api/student/submit {subjectId, mode, answers[], sessionDate, attemptId}",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "opacity": 100,
      "angle": 0,
      "roughness": 0,
      "fontWeight": "normal",
      "boundElements": []
    },
    {
      "id": "el_348",
      "type": "text",
      "x": 1670,
      "y": 972,
      "width": 664,
      "height": 15.399999999999999,
      "text": "3.  For each answer:",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "opacity": 100,
      "angle": 0,
      "roughness": 0,
      "fontWeight": "normal",
      "boundElements": []
    },
    {
      "id": "el_349",
      "type": "text",
      "x": 1670,
      "y": 989,
      "width": 664,
      "height": 15.399999999999999,
      "text": "      a. recordAssessmentResult() → SCORES_DB (update weakness + mastery)",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "opacity": 100,
      "angle": 0,
      "roughness": 0,
      "fontWeight": "normal",
      "boundElements": []
    },
    {
      "id": "el_350",
      "type": "text",
      "x": 1670,
      "y": 1006,
      "width": 664,
      "height": 15.399999999999999,
      "text": "      b. weakness: +1 wrong / -0.1 correct",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "opacity": 100,
      "angle": 0,
      "roughness": 0,
      "fontWeight": "normal",
      "boundElements": []
    },
    {
      "id": "el_351",
      "type": "text",
      "x": 1670,
      "y": 1023,
      "width": 664,
      "height": 15.399999999999999,
      "text": "      c. mastery: write __mastery__:source:weight:date:qkey to attempted_qhashes",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "opacity": 100,
      "angle": 0,
      "roughness": 0,
      "fontWeight": "normal",
      "boundElements": []
    },
    {
      "id": "el_352",
      "type": "text",
      "x": 1670,
      "y": 1040,
      "width": 664,
      "height": 15.399999999999999,
      "text": "4.  If mode=='pre' && wrong answers exist:",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "opacity": 100,
      "angle": 0,
      "roughness": 0,
      "fontWeight": "normal",
      "boundElements": []
    },
