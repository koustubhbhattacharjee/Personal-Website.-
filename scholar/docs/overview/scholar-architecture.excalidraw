      "id": "el_353",
      "type": "text",
      "x": 1670,
      "y": 1057,
      "width": 664,
      "height": 15.399999999999999,
      "text": "      applySwap() → push wrong Qs to today | displace Qs to next class (+7d)",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "opacity": 100,
      "angle": 0,
      "roughness": 0,
      "fontWeight": "normal",
