      "width": 664,
      "height": 15.399999999999999,
      "text": "7.  Frontend renders results screen",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
