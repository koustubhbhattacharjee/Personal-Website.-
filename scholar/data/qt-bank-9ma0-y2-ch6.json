          "question_format": "mcq",
          "question": "Prove the identity $\\text{cosec } \\theta - \\sin \\theta \\equiv X$. Identify the correct expression for $X$.",
          "options": [
            "$\\cos \\theta \\cot \\theta$",
            "$\\cos \\theta \\tan \\theta$",
            "$\\sec \\theta$",
            "$\\cos^2 \\theta$"
          ],
          "correct_option": "A",
          "explanation": "$\\text{cosec } \\theta - \\sin \\theta = \\frac{1}{\\sin \\theta} - \\sin \\theta = \\frac{1 - \\sin^2 \\theta}{\\sin \\theta} = \\frac{\\cos^2 \\theta}{\\sin \\theta} = \\cos \\theta \\cdot \\cot \\theta$.",
          "diagram_required": "none"
