          "question": "A ship leaves port O with position vector (0, 0) and travels with velocity (3, 4) km/h. What is the ship's position after 2 hours?",
          "options": ["(6, 8)", "(3, 4)", "(5, 6)", "(8, 10)"],
          "correct_option": "A",
          "explanation": "Position = initial + t × velocity = (0,0) + 2(3,4) = (6, 8).",
          "diagram_required": "none"
        },
        {
          "question_format": "mcq",
          "question": "At time t hours, a particle has position vector r = (2t)i + (t² - 1)j. What is the speed of the particle when t = 2?",
          "options": ["√20", "√8", "√10", "√17"],
          "correct_option": "A",
          "explanation": "Velocity = dr/dt = 2i + 2tj. At t = 2: v = 2i + 4j. Speed = |v| = √(4 + 16) = √20.",
          "diagram_required": "none"
        }
