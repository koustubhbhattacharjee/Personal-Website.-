      "title": "Exercise 11E — Collinearity",
      "section_ref": "11.5",
      "unit_label": "Chapter 11 — Vectors",
      "primary_slo": "9MA0.P2.7.1.4",
      "aligned_slos": [],
      "questions": [
        {
          "question_format": "mcq",
          "question": "Points A, B, C have position vectors 2a, 5a - b, 8a - 2b respectively. Which statement proves A, B, C are collinear?",
          "options": [
            "BC = 2AB, so BC is parallel to AB and they share point B",
            "AB = BC, so the points form an equilateral triangle",
            "|AB| = |BC|, so the points are equidistant",
            "AB + BC = AC, which is always true"
          ],
          "correct_option": "A",
          "explanation": "AB = 3a - b, BC = 3a - b = AB. Since BC = AB (a scalar multiple, k=1), the vectors are parallel and B is common, proving A, B, C are collinear.",
          "diagram_required": "none"
        }
      ]
    },
