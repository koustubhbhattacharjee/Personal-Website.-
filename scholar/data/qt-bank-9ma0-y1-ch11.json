        {
          "question_format": "mcq",
          "question": "In triangle OAB, OA = a and OB = b. M is the midpoint of AB. Which expression gives OM?",
          "options": ["½(a + b)", "½(b - a)", "a + ½b", "½a - ½b"],
          "correct_option": "A",
          "explanation": "OM = OA + AM = a + ½AB = a + ½(b - a) = ½a + ½b = ½(a + b).",
          "diagram_required": "none"
        },
        {
          "question_format": "mcq",
          "question": "OABC is a parallelogram where OA = a and OC = c. What is the vector from O to the intersection of the diagonals?",
          "options": ["½(a + c)", "a + c", "½(a - c)", "a - c"],
          "correct_option": "A",
          "explanation": "The diagonals of a parallelogram bisect each other. The midpoint of OB (where OB = a + c) is ½(a + c).",
          "diagram_required": "none"
        }
      ]
