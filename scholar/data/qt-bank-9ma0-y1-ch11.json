        {
          "question_format": "mcq",
          "question": "A has position vector 3i + j and B has position vector 7i + 5j. P divides AB in the ratio 1:3. Find the position vector of P.",
          "options": ["4i + 2j", "5i + 3j", "4i + 4j", "6i + 4j"],
          "correct_option": "A",
          "explanation": "OP = OA + (1/4)AB = (3i + j) + (1/4)(4i + 4j) = 3i + j + i + j = 4i + 2j.",
          "diagram_required": "none"
        }
      ]
