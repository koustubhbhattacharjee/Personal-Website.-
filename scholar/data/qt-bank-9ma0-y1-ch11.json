      "questions": [
        {
          "question_format": "mcq",
          "question": "Points A and B have position vectors a = 2i + 3j and b = 6i - j. Find the position vector of the midpoint M of AB.",
          "options": ["4i + j", "4i - j", "2i + j", "8i + 2j"],
          "correct_option": "A",
          "explanation": "M = ½(a + b) = ½((2+6)i + (3-1)j) = ½(8i + 2j) = 4i + j.",
          "diagram_required": "none"
        },
        {
          "question_format": "mcq",
          "question": "A has position vector (1, 5) and B has position vector (7, 2). Find |AB|.",
          "options": ["√45", "√61", "√85", "9"],
          "correct_option": "A",
          "explanation": "AB = (7-1, 2-5) = (6, -3). |AB| = √(36 + 9) = √45 = 3√5.",
          "diagram_required": "none"
        }
