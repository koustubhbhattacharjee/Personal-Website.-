      "questions": [
        {
          "question_format": "mcq",
          "question": "A curve has equation $y = \\sin 5x + \\cos 3x$. Find the gradient of the tangent at the point $(\\pi, -1)$.",
          "options": [
            "$-5$",
            "$5$",
            "$-3$",
            "$3$"
          ],
          "correct_option": "A",
          "explanation": "Differentiate: $\\frac{dy}{dx} = 5\\cos 5x - 3\\sin 3x$. At $x = \\pi$: $\\cos 5\\pi = -1$ and $\\sin 3\\pi = 0$, so the gradient is $5(-1) - 3(0) = -5$.",
          "diagram_required": "none"
        }
      ]
