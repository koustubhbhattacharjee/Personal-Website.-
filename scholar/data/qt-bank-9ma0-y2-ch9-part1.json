      "questions": [
        {
          "question_format": "mcq",
          "question": "A curve has equation $y = \\sin 2x + \\cos 2x$. Find the $x$-coordinates of the stationary points in the interval $0 \\le x \\le \\pi$.",
          "options": [
            "$x = \\frac{\\pi}{8}, \\frac{5\\pi}{8}$",
            "$x = \\frac{\\pi}{4}, \\frac{3\\pi}{4}$",
            "$x = \\frac{\\pi}{8}, \\frac{3\\pi}{8}$",
            "$x = \\frac{3\\pi}{8}, \\frac{7\\pi}{8}$"
          ],
          "correct_option": "A",
          "explanation": "Differentiate: $\\frac{dy}{dx} = 2\\cos 2x - 2\\sin 2x = 0 \\implies \\tan 2x = 1$. In $0 \\le 2x \\le 2\\pi$: $2x = \\frac{\\pi}{4}, \\frac{5\\pi}{4}$, giving $x = \\frac{\\pi}{8}$ and $\\frac{5\\pi}{8}$.",
          "diagram_required": "none"
        }
      ]
    },
