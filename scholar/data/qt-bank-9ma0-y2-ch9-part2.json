        {
          "question_format": "mcq",
          "question": "Find the $x$-coordinate of the point of inflection for the function $f(x) = 2x^2 \\ln x$, for $x > 0$.",
          "options": [
            "$e^{-1.5}$",
            "$e^{-1}$",
            "$1.5$",
            "$e^{1.5}$"
          ],
          "correct_option": "A",
          "explanation": "$f'(x) = 4x\\ln x + 2x$, so $f''(x) = 4\\ln x + 4 + 2 = 4\\ln x + 6$. Setting $f''(x)=0$: $\\ln x = -1.5 \\implies x = e^{-1.5}$.",
          "diagram_required": "none"
        }
      ]
