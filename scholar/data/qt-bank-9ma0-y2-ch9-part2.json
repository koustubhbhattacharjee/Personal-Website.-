        {
          "question_format": "mcq",
          "question": "Given $x = \\text{cosec } 5y$, find an expression for $\\frac{dy}{dx}$ in terms of $x$.",
          "options": [
            "$\\frac{-1}{5x\\sqrt{x^2-1}}$",
            "$\\frac{1}{5x\\sqrt{x^2-1}}$",
            "$-5x\\sqrt{x^2-1}$",
            "$\\frac{-1}{5\\text{cosec } 5y \\cot 5y}$"
          ],
          "correct_option": "A",
          "explanation": "$\\frac{dx}{dy} = -5 \\text{cosec } 5y \\cot 5y$, so $\\frac{dy}{dx} = \\frac{-1}{5 \\text{cosec } 5y \\cot 5y}$. Since $\\text{cosec } 5y = x$ and $\\cot 5y = \\sqrt{x^2-1}$, this gives $\\frac{-1}{5x\\sqrt{x^2-1}}$.",
          "diagram_required": "none"
        }
      ]
