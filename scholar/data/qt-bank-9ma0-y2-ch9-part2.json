        {
          "question_format": "mcq",
          "question": "The surface area $A$ of a cube expands at $2 \\text{ cm}^2 \\text{ s}^{-1}$. Which expression gives $\\frac{dV}{dt}$?",
          "options": [
            "$\\frac{1}{2}V^{1/3}$",
            "$V^{1/3}$",
            "$2V^{1/3}$",
            "$\\frac{1}{4}V^{1/3}$"
          ],
          "correct_option": "A",
          "explanation": "$V=x^3$, $A=6x^2=6V^{2/3}$. So $\\frac{dA}{dV} = 4V^{-1/3}$ and $\\frac{dV}{dA} = \\frac{V^{1/3}}{4}$. By chain rule: $\\frac{dV}{dt} = \\frac{V^{1/3}}{4} \\times 2 = \\frac{1}{2}V^{1/3}$.",
          "diagram_required": "none"
        }
      ]
