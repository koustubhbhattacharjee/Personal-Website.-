      "questions": [
        {
          "question_format": "mcq",
          "question": "A student correctly calculates $f''(5) = 0$ for $f(x) = (x-5)^4$ but is told the point is not a point of inflection. Why?",
          "options": [
            "The second derivative does not change sign at $x=5$.",
            "The first derivative is also zero at $x=5$.",
            "The function is undefined at $x=5$.",
            "The function is linear at $x=5$."
          ],
          "correct_option": "A",
          "explanation": "$f''(x) = 12(x-5)^2 \\ge 0$ on both sides of $x=5$, so the concavity does not change. A point of inflection requires a sign change in $f''$.",
          "diagram_required": "none"
        }
